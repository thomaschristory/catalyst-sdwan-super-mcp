# Copy to .env and fill in your vManage credentials.
#
# Defaults below match the Cisco DevNet always-on SD-WAN sandbox:
#   https://developer.cisco.com/sdwan/sandbox/
# Replace with your own credentials when pointing at a real vManage.

VMANAGE_USERNAME=devnetuser
VMANAGE_PASSWORD=RG!_Yw919_83

# Shared bearer token for HTTP-transport auth (sse, streamable-http).
# Only required when transport.auth.type=bearer in config.yaml.
SDWAN_MCP_TOKEN=
